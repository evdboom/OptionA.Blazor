@namespace OptionA.Blazor.Blog
@using OptionA.Blazor.Playground
@if (Content is not null)
{
    switch (Content.Type)
    {
        case ContentType.Text:
        case ContentType.Paragraph:
        case ContentType.Bold:
        case ContentType.Block:
        case ContentType.Inline:
        case ContentType.Link:
        case ContentType.Italic:
        case ContentType.LineBreak:
        case ContentType.Cite:
            <OptAText Content="(TextContent)Content" />
            break;
        case ContentType.Quote:
            <OptAQuote Content="(QuoteContent)Content" />
            break;
        case ContentType.Code:
            <OptACode Content="(CodeContent)Content" />
            break;
        case ContentType.Header:
            <OptAHeader Content="(HeaderContent)Content" />
            break;
        case ContentType.Icon:
            <OptAIcon Content="(IconContent)Content" />
            break;
        case ContentType.Image:
            <OptAImage Content="(ImageContent)Content" />
            break;
        case ContentType.Frame:
            <OptAFrame Content="(FrameContent)Content" />
            break;
        case ContentType.List:
            <OptAList Content="(ListContent)Content" />
            break;
        case ContentType.Table:
            <OptATable Content="(TableContent)Content" />
            break;
        case ContentType.ContentGroup:
            <OptAContentGroup Content="(ContentGroupContent)Content" />
            break;
        case ContentType.Playground:
            {
                var playgroundContent = (OptionA.Blazor.Blog.Document.Internal.PlaygroundDirectiveContent)Content;
                if (playgroundContent.ResolvedDescriptor is not null)
                {
                    <OptAPlayground Descriptor="playgroundContent.ResolvedDescriptor" />
                }
                else if (playgroundContent.ErrorMessage is not null)
                {
                    <div class="opta-playground-error" role="alert">
                        <strong>Playground error:</strong> @playgroundContent.ErrorMessage
                    </div>
                }
            }
            break;
        case ContentType.InlineComponent:
            {
                var inlineContent = (OptionA.Blazor.Blog.Document.Internal.InlineComponentContent)Content;
                var inlineParams = inlineContent.ComponentType is not null
                    ? OptionA.Blazor.Blog.Document.Internal.ParameterCoercer.Coerce(inlineContent.ComponentType, inlineContent.RawAttributes)
                    : new Dictionary<string, object?>();
                if (inlineContent.ComponentType is not null)
                {
                    <DynamicComponent Type="inlineContent.ComponentType" Parameters="inlineParams" />
                }
                else
                {
                    <span class="opta-document-component-warning" role="alert">
                        @System.Net.WebUtility.HtmlEncode(inlineContent.TagName)@(inlineContent.WarningMessage is not null ? $" — {inlineContent.WarningMessage}" : string.Empty)
                    </span>
                }
            }
            break;
    }
}